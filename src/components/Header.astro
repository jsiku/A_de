---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">Siku.name</a>
<button id="menu-toggle" class="menu-toggle" aria-label="메뉴 열기">
  <span class="line"></span>
  <span class="line"></span>
  <span class="line"></span>
</button>
    <nav id="site-nav">
      <a href="/memos">Memos</a>
      <a href="/minis">Minis</a>
      <a href="/links">Links</a>
      <a href="/archive">Archive</a>
      <a href="/hej">Hej!</a>
      <a href="/rss.xml" class="feedLinkForToggleMenu">Feed</a>
    </nav>
  </div>
</header>

<style>
  /*.site-header {
    position: sticky;
    top: 0;
    background: #2e353d;
    z-index: 1000;
    border-bottom: 1px solid #f0f0f0;
  }*/
  .site-header {
    position: sticky;
    top: 0;
    background: #F0F1E8;
    z-index: 4000;
  }
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.2rem 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo { font-weight: 600; color: #2b2b2b; text-decoration: none; font-size: 1.2rem; letter-spacing: -0.5px; }
  nav { display: flex; gap: 2rem; }
  nav a { color: #2b2b2b; text-decoration: none; font-weight: 500; font-size: 1rem; }


.menu-toggle {
  display: none; /* 데스크탑에선 숨김 */
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  z-index: 1100;
}
.line { width: 22px; height: 2px; background: #2b2b2b; transition: 0.3s; }
.feedLinkForToggleMenu {display: none;}

/* 모바일 전용 (600px) */
@media (max-width: 600px) {
.menu-toggle {
    display: flex;
    position: relative; /* 혹은 fixed */
    z-index: 9000; /* 메뉴판(8000)보다 높게 설정 */
  }
nav {
    display: flex;
    position: fixed;
    top: 0;
    right: -100%; /* 숨김 상태 */

    /* 폭 조절: 너무 크지 않게 200px~250px 추천 */
    width: 240px;
    height: 100vh;
    background: #E1DDD1;

    /* 정렬: 왼쪽 정렬로 변경 */
    flex-direction: column;
    justify-content: center;
    align-items: flex-start; /* 왼쪽 정렬 */
    padding-left: 40px; /* 왼쪽 여백 */

    gap: 1.5rem; /* 간격 살짝 조절 */
    transition: right 0.4s ease;
    z-index: 8000;
  }

  nav.is-active { right: 0; } /* 열림 상태 */
  /* 3. 메뉴 내 텍스트 왼쪽 정렬 강조 */
  nav a {
    width: 100%;
    text-align: left;
    font-size: 1.1rem;
  }
}

  /* X자 애니메이션 */
  .menu-toggle.is-active .line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.is-active .line:nth-child(2) { opacity: 0; }
  .menu-toggle.is-active .line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .feedLinkForToggleMenu {display: flex;}
}
</style>
<script>
  const btn = document.getElementById('menu-toggle');
  const nav = document.getElementById('site-nav'); // <nav id="site-nav">로 ID 추가 필요

  btn?.addEventListener('click', () => {
    btn.classList.toggle('is-active');
    nav?.classList.toggle('is-active');
  });
</script>