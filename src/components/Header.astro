---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">Siku.name</a>
    <nav>
      <a href="/memos">Memos</a>
      <a href="/minis">Minis</a>
      <a href="/hej">Hej!</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background: #2e353d;
    z-index: 1000;
    border-bottom: 1px solid #f0f0f0;
  }
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.2rem 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo { font-weight: 600; color: #fff; text-decoration: none; font-size: 1.2rem; letter-spacing: -0.5px; }
  nav { display: flex; gap: 2rem; }
  nav a { color: #fff; text-decoration: none; font-weight: 500; font-size: 1rem; }

  @media (max-width: 600px) {
    nav { gap: 1rem; }
    nav a, .logo { font-size: 0.95rem; }
  }
</style>
