---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">Siku.name</a>
    <nav>
      <a href="/memos">Memos</a>
      <a href="/minis">Minis</a>
      <a href="/hej">Hej!</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 1000;
  }
  .header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.2rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo { font-weight: 800; color: #111; text-decoration: none; font-size: 1.2rem; }
  nav { display: flex; gap: 2rem; }
  nav a { color: #111; text-decoration: none; font-weight: 500; font-size: 1rem; }
  
  /* 모바일 뷰: 토글 없이 글씨 크기와 간격만 줄여서 한 줄에 다 보이게 처리 */
  @media (max-width: 600px) {
    .header-inner { padding: 1rem 10px; }
    nav { gap: 1rem; }
    nav a, .logo { font-size: 0.9rem; }
  }
</style>
