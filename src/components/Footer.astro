---
interface Props { hideEmailFooter?: boolean; }
const { hideEmailFooter = false } = Astro.props;
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  {!hideEmailFooter && (
    <div class="footer-top">
      <div class="footer-inner">
        <h3>Stay updated!</h3>
        <p>RSS로 새글을 확인해 보세요</p>
        <div class="rss-wrapper">
          <a href="/rss.xml" class="rss-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
            Subscribe
          </a>
        </div>
      </div>
    </div>
  )}
  <div class="footer-bottom">
    <div class="footer-inner">
      <p>&copy; {currentYear} Siku. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { text-align: center; }
  
  /* 첫 번째 푸터: 옅은 회색 */
  .footer-top { background-color: #f5f5f5; padding: 4rem 0; }
  .footer-inner { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .footer-top h3 { margin: 0 0 0.5rem 0; font-size: 1.5rem; color: #111; }
  .footer-top p { margin: 0 0 1.5rem 0; color: #555; }
  
  /* 어두운 배경, 흰 글씨의 RSS 버튼 구역 */
  .rss-wrapper {
    background-color: #111;
    display: inline-block;
    border-radius: 4px;
    padding: 0.8rem 2rem;
  }
  .rss-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    text-decoration: none;
    font-weight: bold;
    font-size: 1.1rem;
  }
  .rss-btn:hover { color: #D4AF37; } /* 호버 시 겨자색 포인트 */

  /* 두 번째 푸터: 더 어두운 색 */
  .footer-bottom { background-color: #eaeaea; padding: 1.5rem 0; color: #666; font-size: 0.9rem; }
  .footer-bottom p { margin: 0; }
</style>
