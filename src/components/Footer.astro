---
interface Props { hideEmailFooter?: boolean; }
const { hideEmailFooter = false } = Astro.props;
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  {!hideEmailFooter && (
    <div class="footer-top">
      <div class="footer-inner">
        <h3>Stay updated!</h3>
        <p>RSS로 새글을 확인해 보세요</p>
        <a href="/rss.xml" class="rss-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
          Subscribe
        </a>
      </div>
    </div>
  )}
  <div class="footer-bottom">
    <div class="footer-inner">
      <p>&copy; {currentYear} Siku.name. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer { text-align: center; }
  .footer-top { background-color: #f5f5f5; padding: 4rem 20px; }
  .footer-top h3 { margin: 0 0 0.5rem 0; font-size: 1.5rem; color: #111; }
  .footer-top p { margin: 0 0 1.5rem 0; color: #555; }
  
  .rss-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: #111;
    color: #fff;
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    padding: 0.8rem 2rem;
    border-radius: 4px;
    transition: all 0.2s;
  }
  .rss-btn:hover { background-color: #333; color: #D4AF37; }

  .footer-bottom { background-color: #e0e0e0; padding: 1.5rem 20px; color: #555; font-size: 0.9rem; }
  .footer-bottom p { margin: 0; }
  .footer-inner { max-width: 900px; margin: 0 auto; }
</style>
