---
import HeroSvg from './HeroSvg.astro';

interface Props { uniqueTags: string[]; }
const { uniqueTags } = Astro.props;
---
<section class="hero-container">
  <HeroSvg />
  <div class="hero-controls">
    <form action="/search/" method="get" class="search-form">
      <input type="text" name="q" placeholder="Type keyword..." required />
      <button type="submit">Search</button>
    </form>
    <div class="tags-container">
      <div class="tags-list">
        {uniqueTags.map(tag => ( <a href={`/tags/${tag}`} class="tag-link">#{tag}</a> ))}
      </div>
      <a href="/tags" class="all-tags-link">All tags</a>
    </div>
  </div>
</section>

<style>
  .hero-container { margin-bottom: 3rem; }
  .hero-controls { max-width: 900px; margin: 0 auto; padding: 2rem 20px; display: flex; flex-direction: column; gap: 1.5rem; }
  .search-form { display: flex; width: 100%; gap: 0.5rem; }
  .search-form input { flex: 1; padding: 0.8rem 1rem; border: 2px solid #111; font-size: 1rem; }
  .search-form button { padding: 0 2rem; background: #111; color: #fff; border: none; font-weight: bold; cursor: pointer; }
  .tags-container { display: flex; justify-content: space-between; align-items: flex-start; width: 100%; }
  .tags-list { display: flex; flex-wrap: wrap; gap: 0.8rem; flex: 1; }
  .tag-link { color: #555; text-decoration: none; font-weight: 500; }
  .tag-link:hover { color: #111; text-decoration: underline; }
  .all-tags-link { color: #111; font-weight: bold; text-decoration: none; border-bottom: 2px solid #111; white-space: nowrap; margin-left: 2rem; }
</style>
