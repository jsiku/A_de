---
---
<div class="hero-svg-wrapper full-bleed">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice">
    <rect width="100%" height="100%" fill="#E3F2FD" />
    
    <!-- 자전거 실루엣 -->
    <g transform="translate(450, 100) scale(0.8)">
      <circle cx="100" cy="200" r="50" fill="none" stroke="#111" stroke-width="8"/>
      <circle cx="300" cy="200" r="50" fill="none" stroke="#111" stroke-width="8"/>
      <path d="M100 200 L150 100 L250 100 L300 200 M150 100 L200 200 L250 100" fill="none" stroke="#111" stroke-width="8"/>
      <circle cx="200" cy="200" r="15" fill="#111"/>
    </g>

    <!-- 흩어진 키캡들 -->
    <g stroke="#333" stroke-width="2" fill="#fff" font-family="sans-serif" font-weight="bold" font-size="14" text-anchor="middle">
      <rect x="750" y="150" width="40" height="40" rx="4" transform="rotate(-10 770 170)"/>
      <text x="770" y="175" transform="rotate(-10 770 170)">Esc</text>
      
      <rect x="820" y="220" width="40" height="40" rx="4" transform="rotate(15 840 240)"/>
      <text x="840" y="245" transform="rotate(15 840 240)">⌘</text>
      
      <rect x="300" y="250" width="40" height="40" rx="4" transform="rotate(-20 320 270)"/>
      <text x="320" y="275" transform="rotate(-20 320 270)">Del</text>

      <rect x="380" y="120" width="40" height="40" rx="4" transform="rotate(5 400 140)"/>
      <text x="400" y="145" transform="rotate(5 400 140)">Fn</text>
    </g>

    <!-- 네이비 블루 텍스트 -->
    <text x="10%" y="30%" font-size="60" font-weight="900" fill="#1E3A8A" text-anchor="start">Moments</text>
    <text x="90%" y="80%" font-size="60" font-weight="900" fill="#1E3A8A" text-anchor="end">in progress</text>
  </svg>
</div>

<style>
  .hero-svg-wrapper { width: 100vw; height: 40vh; min-height: 300px; margin-left: calc(-50vw + 50%); overflow: hidden; }
</style>
