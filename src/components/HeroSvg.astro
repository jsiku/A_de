---
<div class="hero-svg-wrapper">
<svg class="bg-svg" width="100%" height="100%" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
  <rect width="100%" height="100%" fill="#faf9f6"/>

  <!-- 자전거 -->
  <g stroke="#E87A5D" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none">
    <circle cx="280" cy="220" r="35" stroke="#4A4A4A" stroke-width="6" />
    <circle cx="480" cy="220" r="35" stroke="#4A4A4A" stroke-width="6" />
    <path d="M 280 220 L 340 160 L 430 160 L 480 220" />
    <path d="M 340 160 L 380 220 L 430 160" />
    <path d="M 330 140 L 350 140" stroke-width="8" stroke="#333"/>
    <path d="M 430 160 L 420 120 L 440 110" stroke="#333" stroke-width="5"/>
  </g>

  <!-- 키캡 -->
  <g transform="translate(140, 90) rotate(-15)">
    <rect width="45" height="45" rx="8" fill="#F4D35E" stroke="#E2C145" stroke-width="2"/>
    <rect x="5" y="5" width="35" height="30" rx="4" fill="#F9E286" />
    <text x="22.5" y="26" font-family="sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">Esc</text>
  </g>
  <g transform="translate(600, 130) rotate(22)">
    <rect width="45" height="45" rx="8" fill="#4B9CB3" stroke="#3B8499" stroke-width="2"/>
    <rect x="5" y="5" width="35" height="30" rx="4" fill="#65B1C6" />
    <text x="22.5" y="27" font-family="sans-serif" font-size="16" font-weight="bold" fill="#fff" text-anchor="middle">⌘</text>
  </g>
  <g transform="translate(200, 300) rotate(-28)">
    <rect width="45" height="45" rx="8" fill="#E66A6A" stroke="#C95454" stroke-width="2"/>
    <rect x="5" y="5" width="35" height="30" rx="4" fill="#F08282" />
    <text x="22.5" y="26" font-family="sans-serif" font-size="14" font-weight="bold" fill="#fff" text-anchor="middle">Del</text>
  </g>
  <g transform="translate(560, 270) rotate(12)">
    <rect width="45" height="45" rx="8" fill="#A8D0E6" stroke="#8CB8CF" stroke-width="2"/>
    <rect x="5" y="5" width="35" height="30" rx="4" fill="#C1E1F2" />
    <text x="22.5" y="26" font-family="sans-serif" font-size="14" font-weight="bold" fill="#333" text-anchor="middle">Fn</text>
  </g>

  <!-- <text x="35%" y="30%" font-size="30" font-weight="800" text-anchor="middle" fill="#1E3A8A" dominant-baseline="middle" letter-spacing="0.01em">Moments</text>
  <text x="55%" y="69%" font-size="28" font-weight="900" text-anchor="middle" fill="#1E3A8A" dominant-baseline="middle" letter-spacing="-0.01em">in progress</text> -->

</svg>

  <div class="text-overlay">
    <svg width="100%" height="100%" viewBox="0 0 400 200" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <text x="23%" y="5%" font-size="35" font-weight="800" text-anchor="middle" fill="#1E3A8A" dominant-baseline="middle" letter-spacing="0.01em">Moments</text>
      <text x="65%" y="92%" font-size="33" font-weight="900" text-anchor="middle" fill="#1E3A8A" dominant-baseline="middle" letter-spacing="-0.01em">in progress</text>
    </svg>
  </div>
</div>

<style>
  .hero-svg-wrapper { width: 100vw; height: 81vh; min-height: 300px;    border-bottom-width: 10px;
    border-bottom-style: solid;
    border-bottom-color: #e9c362;    position: relative;
    overflow: hidden;}
      .bg-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
    .text-overlay {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%); /* 정확히 가운데로 당겨옴 */
    width: 100%;
    max-width: 900px; /* PC에서는 최대 900px, 모바일에서는 100%로 줄어듦 */
    height: 100%;
    z-index: 2; /* 배경보다 위로 오게 설정 */
    pointer-events: none; /* 글씨 투명 영역 때문에 아래의 요소가 클릭 안 되는 현상 방지 */
  }
</style>
