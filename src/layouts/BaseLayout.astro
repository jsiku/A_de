---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  hideEmailFooter?: boolean;
}

const { title, hideEmailFooter = false } = Astro.props;
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    body { margin: 0; font-family: sans-serif; background: #fff; color: #111; }
    
    /* 전체 컨테이너는 900px */
    .main-container {
      max-width: 900px;
      margin: 0 auto;
    }

    /* 본문 영역 브레이크아웃 레이아웃 */
    .prose {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }
    
    /* 글 쓰는 영역은 무조건 가운데 680px */
    .prose > * {
      width: 100%;
      max-width: 680px;
    }
    
    /* 이미지가 들어갈 경우 900px에 꽉 차게 확장 */
    .prose > img, .prose > svg, .full-bleed {
      max-width: 900px;
      width: 100%;
      height: auto;
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer hideEmailFooter={hideEmailFooter} />
</body>
</html>
