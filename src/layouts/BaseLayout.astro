---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  hideEmailFooter?: boolean;
}

const { title, hideEmailFooter = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="ko">
  <head>
        <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MHMQRWZ4');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="192x192"  href="/android-icon-192x192.png">
    </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MHMQRWZ4"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />

    <main>
      <slot />
    </main>

    <Footer hideEmailFooter={hideEmailFooter} />
  </body>
</html>

<style is:global>
  /* ✨ 1번 문제 해결: 헤더와 이미지 사이의 불필요한 간격 및 브라우저 기본 여백 완벽 제거 */
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    width: 100%;
    overflow-x: clip;
    background-color: #F0F1E8;
    font-family: "Ubuntu Mono", "Bodoni Roman", Bodoni, "Nanum Myeongjo", serif;
  }


  /* 본문 중앙 정렬용 기본 클래스 (Hej 페이지 등의 680px 폭 유지) */
  .prose {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 20px;
  }
  a,
a:visited,
a:hover,
a:active {
  color: #da4939;
  text-decoration: none;
}
</style>
