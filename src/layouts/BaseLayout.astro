---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  hideEmailFooter?: boolean;
}

const { title, hideEmailFooter = false } = Astro.props;
---
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style is:global>
    /* 리셋 및 기본 폰트 */
    *, *::before, *::after { box-sizing: border-box; }
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background: #fff; color: #111; line-height: 1.6; }
    
    /* 전체 컨테이너는 무조건 가운데 900px */
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* 본문 브레이크아웃(Breakout) 레이아웃 마법 */
    .prose {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
    }
    
    /* 글 쓰는 영역은 가운데 680px로 모아줌 */
    .prose > * {
      width: 100%;
      max-width: 680px;
    }
    
    /* 이미지가 들어갈 경우 900px(부모 너비)에 꽉 차게 확장 */
    .prose > img, .prose > svg, .full-bleed {
      max-width: 900px !important;
      width: 100%;
      height: auto;
      margin: 2rem 0;
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer hideEmailFooter={hideEmailFooter} />
</body>
</html>
