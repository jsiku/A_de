---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  hideEmailFooter?: boolean;
}

const { title, hideEmailFooter = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer hideEmailFooter={hideEmailFooter} />
  </body>
</html>

<style is:global>
  /* ✨ 1번 문제 해결: 헤더와 이미지 사이의 불필요한 간격 및 브라우저 기본 여백 완벽 제거 */
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    width: 100%;
    overflow-x: clip;
  }

  /* ✨ 2번 문제 해결: 어떤 컨테이너 안에 있더라도 브라우저 좌우 끝까지 100vw로 뻗어나가는 마법의 클래스 */
  .full-bleed {
    width: 100vw !important;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw !important;
    margin-right: -50vw !important;
  }

  /* 본문 중앙 정렬용 기본 클래스 (Hej 페이지 등의 680px 폭 유지) */
  .prose {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 20px;
  }
</style>
