---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  // 1. 모든 글(메모 포함)을 날짜순으로 정렬합니다.
  const sortedAll = allEntries.sort((a, b) => {
    const isAPinned = a.data.pinned === true;
    const isBPinned = b.data.pinned === true;

    // ✨ u 설정: updated가 있으면 updated, 없으면 date의 타임스탬프 값 추출
    const aDate = a.data.updated ? a.data.updated.valueOf() : a.data.date.valueOf();
    const bDate = b.data.updated ? b.data.updated.valueOf() : b.data.date.valueOf();

    // 1순위: Pinned 상태 비교, 2순위: u(최신 날짜) 기준 정렬
    if (isAPinned === isBPinned) {
      return bDate - aDate;
    }
    return isAPinned ? -1 : 1;
  });

  // 2. 하단 이전/다음(older/newer) 링크 계산을 위해 일반 포스트만 따로 추려냅니다.
  const postsOnly = sortedAll.filter(
    p => !['memo', 'links'].includes(p.data.type) && !p.data.archived
  );
  // ✨ 핵심 수정 부분: log 페이지에 보여줄 글들만 따로 필터링합니다. (아카이브 제외)
  const logEntries = sortedAll.filter((post) => !post.data.archived);

  // 3. 메모를 포함한 '모든 글'에 대해 고유 페이지 경로를 생성합니다.
  return logEntries.map((post) => {
    let prevPost = null;
    let nextPost = null;

    // 현재 페이지가 일반 'post'일 때만 이전/다음 글 링크를 계산하여 연결합니다.
    if (post.data.type !== 'memo') {
      const index = postsOnly.findIndex(p => p.id === post.id);
      if (index !== -1) {
        prevPost = index + 1 < postsOnly.length ? postsOnly[index + 1] : null;
        nextPost = index - 1 >= 0 ? postsOnly[index - 1] : null;
      }
    }

    return {
      params: { id: post.id }, // 여기서 메모도 자신만의 고유 주소를 얻게 됩니다!
      props: {
        post,
        prevPost,
        nextPost,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

// ✨ 날짜 포맷 변환 함수 (DD. Mon. YYYY 형태)
function formatDate(dateStr: Date | string) {
  const d = new Date(dateStr);
  const day = d.getDate();
  const month = d.toLocaleString('en-US', { month: 'short' });
  const year = d.getFullYear();
  return `${day} ${month} ${year}`;
}

// ✨ 작성일 및 수정일 조합 (수정일이 있을 때만 Updated 문구 추가)
const createdStr = `${formatDate(post.data.date)},`;
const updatedStr = post.data.updated ? ` updated ${formatDate(post.data.updated)},` : '';
const displayDate = createdStr + updatedStr;

// 형님께서 직접 수정하셨던 완벽한 날짜 포맷 로직 적용!
const postDate = new Date(post.data.date).toISOString().split('T')[0].replace(/-/g, '.');
---
<BaseLayout title={`${post.data.title || 'Post'} | Siku.name`}>

  <!-- 포스트 전용 고정 메뉴바 (겨자색 톤 적용) -->
  {post.data.type !== 'memo' && (
    <div class="post-navbar" id="postNavbar">
      <div class="post-navbar-inner">
        <a href={prevPost ? `/log/${prevPost.id}` : '#'} class={!prevPost ? 'disabled' : ''}>&lt; older</a>
        <div class="center-menu">
          <a href="/" class="index-btn">▲ Index</a>
          <span class="reading-title">Reading: {post.data.title}</span>
        </div>
        <a href={nextPost ? `/log/${nextPost.id}` : '#'} class={!nextPost ? 'disabled' : ''}>newer &gt;</a>
      </div>
    </div>
  )}

  <!-- 커버 이미지 영역: 화면을 좌우 꽉 채우고 고정 (패럴랙스) -->
  {post.data.cover && (
    <div id="fade-cover" class="fixed-cover-container">
      <div class="cover-overlay"></div>
      <img src={post.data.cover.src} alt="Cover" class="full-bleed-cover" />
    </div>
  )}

  <!-- 본문 영역: 이미지 밑에 있다가 위로 덮으며 올라옴 -->
  <article class={`post-content-wrapper ${!post.data.cover ? 'no-cover' : ''}`} data-pagefind-body>
     <div class="post-header prose">
        <div class="post-meta">
          <span class="date">{displayDate}</span>
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
            {post.data.pinned && <span class="tag pinned-badge">Pinned</span>}
          </div>
        </div>
        <h1 class="post-main-title">{post.data.title}</h1>
     </div>

    <div class="prose">
      <Content />
      {/* ✨ 메모(memo) 타입일 때만 본문 마지막 줄 아래에 뒤로가기 링크 추가 */}
      {post.data.type === 'memo' && (
        <div class="memo-back-container">
          <a href="javascript:history.back()" class="memo-back-link">Back &gt;</a>
        </div>
      )}
    </div>
  </article>

</BaseLayout>

<style>
  /* 포스트 전용 고정 메뉴바 */
  .post-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #E1DDD1;
    color: #111;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 2000;
  }
  .post-navbar.visible {
    transform: translateY(0);
  }
  .post-navbar-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.8rem 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
  }
  .post-navbar a { color: #111; text-decoration: none; transition: opacity 0.2s; }
  .post-navbar a:hover { opacity: 0.6; }
  .disabled { opacity: 0.3; pointer-events: none; }

  .center-menu {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .index-btn {
    transition: all 0.2s;
  }
  .index-btn:hover {
    background: rgba(255, 255, 255, 0.4);
  }
  .reading-title {
    font-weight: 500;
    opacity: 0.8;
  }

  /* 메타 정보 디자인 */
.post-header {
  margin-bottom: 3rem;
  text-align: left;
}

.post-main-title {
  font-size: 3rem;
  margin: 0 0 1rem 0;
  line-height: 1.4;
}

.post-meta {
  display: flex;
  flex-direction: row;   /* ← 세로 → 가로 */
  align-items: center;   /* ← 왼쪽 정렬 */
  gap: 0.6rem;
}

.date {
  color: #888;
  font-size: 1rem;
  font-family: monospace;
}

.tags {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: flex-start;  /* ← 중앙 → 왼쪽 */
}

.tag {
  color: #666;
  font-size: 0.9rem;
  text-decoration: none;
  transition: background 0.2s;
}

.tag:hover {
  background: #D4AF37;
  color: #111;
}


   /* ✨ Pinned 뱃지 전용 고정 스타일 추가 */
  .pinned-badge {
    background-color: #E1DDD1 !important; /* 항상 겨자색 유지 */
    color: #111 !important;               /* 진한 글씨 유지 */
    font-weight: bold;
    cursor: default;                      /* 링크가 아니므로 일반 마우스 커서 적용 */
  }

  /* 마우스가 올라가도 색이 변하거나 밑줄이 안 생기도록 고정 */
  .pinned-badge:hover {
    text-decoration: none;
  }

    .prose :global(img) {
    width: 900px !important;             /* prose의 기본 너비 제한을 강제로 뚫음 */
    height:auto !important;            /* 이미지의 원본 비율 유지 */
    max-width: 100vw !important;         /* 모바일에서는 화면 폭에 맞춤 */
    position: relative !important;
    left: 50% !important;                /* 부모(680px)의 중앙으로 왼쪽 끝을 밀어냄 */
    transform: translateX(-50%) !important; /* 이미지 폭의 절반만큼 다시 당겨서 완벽한 중앙 정렬 */
    display: block !important;
    margin-top: 3rem !important;         /* 이미지 위아래 여백 */
    margin-bottom: 3rem !important;
  }

  /* ✨ 메모 뒤로가기 링크 스타일 */
  .memo-back-container {
    margin-top: 1rem;   /* 본문 마지막 줄과 여유로운 간격 */
    text-align: right;   /* 화면 왼쪽에 배치 */
  }

  .memo-back-link {
    color: #888;              /* 기본은 눈에 띄지 않는 차분한 회색 */
    text-decoration: none;    /* 밑줄 제거 */
    font-size: 0.95rem;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .memo-back-link:hover {
    color: #111;              /* 마우스를 올리면 진한 검은색으로 강조 */
    text-decoration: underline; /* 살짝 밑줄이 생기며 클릭 유도 */
  }

/* ✨ BaseLayout 헤더 예외 처리: 스크롤 시 sticky를 무시하고 위로 자연스럽게 올라감 */
  :global(.site-header) {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 3000;
    background: #f0f1e8dd !important;
  }

  /* =========================================
     커버 이미지 및 아티클 레이아웃 (수정됨)
     ========================================= */

  /* 💻 데스크탑 기본 (900px 초과): 화면 전체 100vh 고정, 폭을 줄이면 좌우가 잘림 */
  .fixed-cover-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh; /* 데스크탑에선 무조건 화면 전체 꽉 채움 */
    z-index: 0;
  }

  .cover-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0);
    z-index: 10;
    pointer-events: none;
  }

  .full-bleed-cover {
    width: 100%;
    height: 100%;
    object-fit: cover; /* 높이가 100vh로 고정되어 있으므로, 폭이 줄어들면 이미지 크기가 줄어들지 않고 좌우가 깎임 */
  }

  /* 본문 영역 */
  .post-content-wrapper {
    position: relative;
    z-index: 100;
    padding: 104vh 20px 1rem;
    min-height: 100vh;
    background-color: #F0F1E8; /* 아티클 배경색이 있어야 이미지를 덮음 */
    box-shadow: 0 -10px 30px rgba(0,0,0,0.05);
    /* 데스크탑에서 시작 시 반투명 (JS에서 조절) */
  }

  .post-content-wrapper.no-cover {
    margin-top: 2rem;
    padding: 4rem 20px 1rem;
    box-shadow: none;
  }

  /* 📱 모바일 반응형 (900px 이하) */
  @media (max-width: 900px) {
    .fixed-cover-container {
      position: sticky; /* 상단에 고정되어 있다가 아티클이 덮음 */
      top: 0;
      height: auto;
    }
    .full-bleed-cover {
      width: 152%;
      height: auto; /* 폭(100%)에 맞춰 원본 비율대로 이미지 전체 크기가 줄어듦 */
      max-width: none !important; /* 혹시 모를 제한 풀기 */
      position: relative;
      left: 50%;
      transform: translateX(-50%);
      display: block;
    }
    .post-content-wrapper {
      margin-top: 0; /* 모바일: 이미지 바로 밑에서 시작 */
      padding: 4rem 20px 1rem;
      opacity: 1 !important; /* 모바일은 항상 아티클이 100% 선명함 */
    }
  }


</style>
<script>
  const handleScroll = () => {
    const isDesktop = window.innerWidth > 900;
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;

    const article = document.querySelector('.post-content-wrapper') as HTMLElement;
    const postHeader = document.querySelector('.post-header') as HTMLElement;
    const coverContainer = document.querySelector('.fixed-cover-container') as HTMLElement;
    const overlay = document.querySelector('.cover-overlay') as HTMLElement;
    const postNavbar = document.getElementById('postNavbar');

    if (!article) return;
    const articleRect = postHeader.getBoundingClientRect();

    // 1. 공통: 포스트 전용  메뉴바 노출 (아티클이 화면 상단에 닿을 즈음)
    if (articleRect.top <= 50) {
      postNavbar?.classList.add('visible');
    } else {
      postNavbar?.classList.remove('visible');
    }

    // 2. 데스크탑 동작: 아티클이 올라오면서 투명 -> 선명해짐
    if (isDesktop) {
      if (overlay) overlay.style.backgroundColor = 'rgba(0,0,0,0)'; // 이미지 오버레이 비활성

      // 아티클이 화면 하단에서 상단으로 올라오는 진행률 (0: 바닥 ~ 1: 꼭대기)
      const progress = 1 - (articleRect.top / windowHeight);

      // 0.3(흐릿함)에서 시작해 위로 절반 이상 오면 1(완전 선명함)이 되도록 설정
      const articleOpacity = Math.min(1, Math.max(0.3, progress * 1.5));
      article.style.opacity = articleOpacity.toString();
    }
    // 3. 모바일 동작: 아티클은 항상 선명, 이미지가 스크롤 할수록 어두워짐
    else {
      article.style.opacity = '1'; // 아티클 투명도 해제

      if (coverContainer && overlay) {
        const coverHeight = coverContainer.offsetHeight;
        // 스크롤한 양을 이미지 높이로 나누어 진행률 계산
        const progress = scrollY / coverHeight;

        // 최대 0.7까지만 어두워지게 제한
        const overlayOpacity = Math.min(1, Math.max(0, progress));
        overlay.style.backgroundColor = `rgba(240,241,232,${overlayOpacity})`;
      }
    }
  };

  // 이벤트 리스너 등록
  window.addEventListener('scroll', handleScroll, { passive: true });
  window.addEventListener('resize', handleScroll); // 창 크기 조절 시 즉시 반응

  // 로드 직후 바로 초기화 함수 한 번 실행
  handleScroll();
</script>