---
import BaseLayout from '../layouts/BaseLayout.astro';
import MemoCard from '../components/MemoCard.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type BlogEntry = CollectionEntry<"blog">;

const allEntries = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// 'memo' 타입만 필터링 후 날짜순 정렬, 그리고 pinned이 true인 글은 상단 고정
const memosOnly = allEntries.filter((entry: BlogEntry) => entry.data.type === 'memo');
const sortedMemos = memosOnly.sort((a, b) => {
  const isAPinned = a.data.pinned === true;
  const isBPinned = b.data.pinned === true;

  // ✨ u 설정: updated가 있으면 updated, 없으면 date의 타임스탬프 값 추출
  const aDate = a.data.updated ? a.data.updated.valueOf() : a.data.date.valueOf();
  const bDate = b.data.updated ? b.data.updated.valueOf() : b.data.date.valueOf();

  // 1순위: Pinned 상태 비교, 2순위: u(최신 날짜) 기준 정렬
  if (isAPinned === isBPinned) {
    return bDate - aDate;
  }
  return isAPinned ? -1 : 1;
});

// 10개 단위 페이지네이션 계산
const POSTS_PER_PAGE = 10;
const totalPages = Math.ceil(memosOnly.length / POSTS_PER_PAGE) || 1;
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);

// '일(DD)' 단위 그룹화 및 pageNum 주입
const groupedMemos: { date: string, entries: (BlogEntry & { pageNum: number })[] }[] = [];

sortedMemos.forEach((entry, index) => {
  const pageNum = Math.floor(index / POSTS_PER_PAGE) + 1;
  const entryWithPage = Object.assign({}, entry, { pageNum });

  // yyyy.mm.dd 포맷
  const targetDate = entry.data.updated || entry.data.date;
  const dateObj = new Date(targetDate);
  const dateStr = `${dateObj.getDate()} ${dateObj.toLocaleString('en-US', { month: 'short' })} ${dateObj.getFullYear()}`;

  const lastGroup = groupedMemos[groupedMemos.length - 1];
  if (!lastGroup || lastGroup.date !== dateStr) {
    groupedMemos.push({ date: dateStr, entries: [entryWithPage] });
  } else {
    lastGroup.entries.push(entryWithPage);
  }
});
---
<BaseLayout title="Memos | Siku.name">

  <!-- Memos 전용 상단 히어로 (좌우 100vw 꽉참) -->
  <div class="page-hero">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 1200 300" preserveAspectRatio="xMidYMid slice" class="hero-bg">
      <rect width="100%" height="100%" fill="#e9c362" />
      <path d="M0,150 Q300,50 600,150 T1200,150 L1200,300 L0,300 Z" fill="#E1E8ED" opacity="0.6"/>
      <circle cx="900" cy="100" r="40" fill="#D4AF37" opacity="0.2"/>
    </svg>
    <div class="hero-content">
      <h1>Memos</h1>
      <p>짧은 생각, 그리고 일상의 파편</p>
    </div>
  </div>

  <!-- 본문 컨테이너 (가운데 800px 정렬) -->
  <div class="content-container">
    <div class="post-list-container">
      {groupedMemos.map(group => (
        <div class="date-group">
          <aside class="date-sidebar">
            <span class="sticky-date">{group.date}</span>
          </aside>

          <div class="date-content">
            {group.entries.map((entry) => (
              <div class="memo-item" data-page={entry.pageNum}>
                <!-- 형님께서 수정하신 대로 post={entry}로 넘깁니다! -->
                <MemoCard post={entry} />
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- 하단 페이지네이션 렌더링 -->
      {totalPages > 1 && (
        <div class="pagination">
          {pages.map((page) => (
            <button class="page-btn" data-target-page={page}>{page}</button>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  const pageBtns = document.querySelectorAll('.page-btn');
  const memoItems = document.querySelectorAll('.memo-item');

  function showPage(page: number) {
    memoItems.forEach((item) => {
      const el = item as HTMLElement;
      el.style.display = parseInt(el.dataset.page || '1') === page ? 'block' : 'none';
    });

    pageBtns.forEach(btn => {
      if (parseInt(btn.getAttribute('data-target-page') || '1') === page) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    // 화면에 보이는 카드가 없는 날짜(Date) 그룹 숨기기
    document.querySelectorAll('.date-group').forEach(group => {
      const visibleItems = group.querySelectorAll('.memo-item[style="display: block;"]');
      (group as HTMLElement).style.display = visibleItems.length > 0 ? 'flex' : 'none';
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  pageBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = parseInt((e.currentTarget as HTMLElement).getAttribute('data-target-page') || '1');
      showPage(target);
    });
  });

  if (pageBtns.length > 0) showPage(1);
</script>

<style>
  /* 히어로 영역 (100vw) */
  .page-hero {
    position: relative;
    height: 30vh;
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-content h1 { font-size: 3.5rem; margin: 0 0 0.5rem 0; color: #111; letter-spacing: -1px; }
  .hero-content p { color: #555; font-size: 1.2rem; margin: 0; }

  /* 본문 영역 (가운데 정렬) */
  .content-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 20px 0 20px;
  }

     /*.month-group { display: flex; gap: 2rem; margin-bottom: 2rem; }
  .month-sidebar { flex: 0 0 100px; }
  .sticky-month { position: sticky; top: 100px; font-size: 1rem; font-weight: 800; color: #111; }
  .month-content { flex: 1; display: flex; flex-direction: column; }*/



  .date-group { display: flex; gap: 2rem; margin-bottom: 2rem; }
  .date-sidebar { flex: 0 0 100px; }
  .sticky-date { position: sticky; top: 100px; font-size: 1.2rem; font-weight: 800; color: #e9c362; }
  .date-content { flex: 1; display: flex; flex-direction: column; }

  .pagination { display: flex; gap: 0.5rem; justify-content: center; margin-top: 3rem; margin-bottom: 5rem; }
  .page-btn { background: none; border: 1px solid #ddd; padding: 0.5rem 1rem; cursor: pointer; font-size: 1rem; color: #555; border-radius: 4px; transition: all 0.2s; }
  .page-btn:hover { background: #f5f5f5; color: #111; }
  .page-btn.active { background: #111; color: #fff; border-color: #111; }

  /* 모바일 뷰 (화면 폭이 768px 이하일 때 적용) */
@media (max-width: 768px) {
  .date-group {
    display: flex;
    flex-direction: column; /* 좌우 배치를 상하(위아래) 배치로 변경 */
    gap: 0rem; /* 날짜와 첫 번째 카드 사이의 여백 */
    margin-bottom: 2rem;
  }
  .date-sidebar {
    width: 100%; /* 왼쪽 한구석이 아니라 모바일 화면 전체 너비를 쓰도록 풀기 */
    margin-bottom: 0.5rem;
    flex: 0 0 10px;
    border-bottom-width: 3px;
    border-bottom-style: solid;
    border-bottom-color: #e9c362;
  }
}
</style>
