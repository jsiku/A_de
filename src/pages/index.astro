---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { canonicalTag } from "../lib/tagAlias";

// 타입 에러 우회를 위한 별칭
type BlogEntry = CollectionEntry<"blog">;

const allEntries = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

// memo 타입 제외
const postsOnly = allEntries.filter((entry: BlogEntry) =>
  !['memo', 'links'].includes(entry.data.type) && entry.data.archived !== true
);

const sortedEntries = postsOnly.sort((a, b) => {
  const isAPinned = a.data.pinned === true;
  const isBPinned = b.data.pinned === true;

  // ✨ u 설정: updated가 있으면 updated, 없으면 date의 타임스탬프 값 추출
  const aDate = a.data.updated ? a.data.updated.valueOf() : a.data.date.valueOf();
  const bDate = b.data.updated ? b.data.updated.valueOf() : b.data.date.valueOf();

  // 1순위: Pinned 상태 비교, 2순위: u(최신 날짜) 기준 정렬
  if (isAPinned === isBPinned) {
    return bDate - aDate;
  }
  return isAPinned ? -1 : 1;
});

// 한 페이지당 10개 표시
const POSTS_PER_PAGE = 10;
const totalPages = Math.ceil(postsOnly.length / POSTS_PER_PAGE) || 1;
const pages = Array.from({ length: totalPages }, (_, i) => i + 1);

const allTags = allEntries.flatMap(entry => (entry.data.tags ?? []).map(canonicalTag));
const uniqueTags = [...new Set(allTags)].sort();

// 월 단위 그룹화 및 pageNum 속성 부여
const groupedEntries: { month: string, entries: (BlogEntry & { pageNum: number })[] }[] = [];

sortedEntries.forEach((entry, index) => {
  const pageNum = Math.floor(index / POSTS_PER_PAGE) + 1;
  const entryWithPage = Object.assign({}, entry, { pageNum });

  const targetDate = entry.data.updated || entry.data.date;
  const dateObj = new Date(targetDate);
  const monthStr = `${dateObj.toLocaleString('en-US', { month: 'short' })} ${dateObj.getFullYear()}`;

  const lastGroup = groupedEntries[groupedEntries.length - 1];
  if (!lastGroup || lastGroup.month !== monthStr) {
    groupedEntries.push({ month: monthStr, entries: [entryWithPage] });
  } else {
    lastGroup.entries.push(entryWithPage);
  }
});
---
<BaseLayout title="Siku.name">
  <Hero uniqueTags={uniqueTags} />

  <div class="post-list-container">
    {groupedEntries.map(group => (
      <div class="month-group">
        <aside class="month-sidebar">
          <span class="sticky-month">{group.month}</span>
        </aside>

        <div class="month-content">
          {group.entries.map(entry => (
            <div class="post-item" data-page={entry.pageNum}>
              <PostCard entry={entry} />
            </div>
          ))}
        </div>
      </div>
    ))}

    <!-- 하단 페이지네이션 렌더링 -->
    {totalPages > 1 && (
      <div class="pagination">
        {pages.map((page) => (
          <button class="page-btn" data-target-page={page}>{page}</button>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const pageBtns = document.querySelectorAll('.page-btn');
  const postItems = document.querySelectorAll('.post-item');

  function showPage(page: number) {
    postItems.forEach((item) => {
      const el = item as HTMLElement;
      el.style.display = parseInt(el.dataset.page || '1') === page ? 'block' : 'none';
    });

    pageBtns.forEach(btn => {
      if (parseInt(btn.getAttribute('data-target-page') || '1') === page) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    document.querySelectorAll('.month-group').forEach(group => {
      const visibleItems = group.querySelectorAll('.post-item[style="display: block;"]');
      (group as HTMLElement).style.display = visibleItems.length > 0 ? 'flex' : 'none';
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  pageBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = parseInt((e.currentTarget as HTMLElement).getAttribute('data-target-page') || '1');
      showPage(target);
    });
  });

  if (pageBtns.length > 0) showPage(1);
</script>

<style>
  .post-list-container { max-width: 900px; margin: 0 auto; padding: 0 20px; }
  .month-group { display: flex; gap: 2rem; border-top-width: 3px;
    border-top-style: solid;
    border-top-color: #E1DDD1; padding-top: 1rem;}
  .month-sidebar { flex: 0 0 100px; }
  .sticky-month { position: sticky; top: 100px; font-size: 1.2rem; font-weight: 800; color: #2b2b2b; }
  .month-content { flex: 1; display: flex; flex-direction: column; }

  .pagination { display: flex; gap: 0.5rem; justify-content: center; margin-top: 3rem; margin-bottom: 5rem; }
  .page-btn { background: none; border: 1px solid #ddd; padding: 0.5rem 1rem; cursor: pointer; font-size: 1rem; color: #555; border-radius: 4px; transition: all 0.2s; }
  .page-btn:hover { background: #f5f5f5; color: #111; }
  .page-btn.active { background: #111; color: #fff; border-color: #111; }




  /* 모바일 뷰 (화면 폭이 768px 이하일 때 적용) */
@media (max-width: 768px) {
  .month-group {
    display: flex;
    flex-direction: column; /* 좌우 배치를 상하(위아래) 배치로 변경 */
    gap: 1rem; /* 날짜와 첫 번째 카드 사이의 여백 */
    margin-bottom: 2rem;
  }
  .month-sidebar {
    width: 100%; /* 왼쪽 한구석이 아니라 모바일 화면 전체 너비를 쓰도록 풀기 */
    margin-bottom: 0.5rem;
    flex: 0 0 10px;
  }
}
</style>
