---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');
  
  // older / newer 링크를 위해 날짜순 정렬
  // 예외 처리 없이 모든 데이터를 렌더링하여 option 구분이 없도록 대응합니다.
  const sorted = allEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((post, index) => {
    return {
      params: { id: post.slug || post.id },
      props: {
        post,
        prevPost: index + 1 < sorted.length ? sorted[index + 1] : null, // 이전 글 (더 오래된 글)
        nextPost: index - 1 >= 0 ? sorted[index - 1] : null, // 다음 글 (더 최신 글)
      }
    }
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

// 이미지 객체(.src) 추출 안전장치
const coverSrc = typeof post.data.cover === 'object' ? post.data.cover?.src : post.data.cover;
const postDate = new Date(post.data.date).toISOString().split('T').replace(/-/g, '.');
---
<BaseLayout title={`${post.data.title || 'Post'} | Siku.name`}>
  
  <!-- 포스트 전용 고정 메뉴바 (겨자색 톤 적용) -->
  <div class="post-navbar" id="postNavbar">
    <div class="post-navbar-inner">
      <a href={prevPost ? `/blog/${prevPost.slug || prevPost.id}` : '#'} class={!prevPost ? 'disabled' : ''}>&lt; older</a>
      <div class="center-menu">
        <a href="/" class="index-btn">▲ Index</a>
        <span class="reading-title">Reading: {post.data.title}</span>
      </div>
      <a href={nextPost ? `/blog/${nextPost.slug || nextPost.id}` : '#'} class={!nextPost ? 'disabled' : ''}>newer &gt;</a>
    </div>
  </div>

  <!-- 커버 이미지 영역: 화면을 꽉 채우고 고정 (패럴랙스) -->
  {coverSrc && (
    <div class="fixed-cover-container" id="coverContainer">
      <img src={coverSrc} alt="Cover Image" class="full-bleed-cover" />
    </div>
  )}

  <!-- 본문 영역: 이미지 밑에 있다가 위로 덮으며 올라옴 -->
  <article class={`post-content-wrapper ${!coverSrc ? 'no-cover' : ''}`}>
     <!-- 작성일 및 태그 등 메타 정보 영역 -->
     <div class="post-header prose">
        <h1 class="post-main-title">{post.data.title}</h1>
        <div class="post-meta">
          <span class="date">{postDate}</span>
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        </div>
     </div>

     <div class="prose">
        <Content />
     </div>
  </article>

</BaseLayout>

<style>
  /* 1. 이 페이지에서만 기존 글로벌 헤더를 absolute로 바꿔서 스크롤 시 자연스럽게 위로 사라지게 함 */
  :global(.site-header) {
    position: absolute !important;
    width: 100%;
  }

  /* 2. 포스트 전용 고정 메뉴바 */
  .post-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #D4AF37;
    color: #111;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 2000;
  }
  .post-navbar.visible {
    transform: translateY(0);
  }
  .post-navbar-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.8rem 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
  }
  .post-navbar a {
    color: #111;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .post-navbar a:hover {
    opacity: 0.6;
  }
  .disabled {
    opacity: 0.3;
    pointer-events: none;
  }
  .center-menu {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .index-btn {
    border-bottom: 2px solid #111;
  }
  .reading-title {
    font-weight: 500;
    opacity: 0.8;
  }

  /* 3. 좌우 꽉 차는 고정 커버 이미지 */
  .fixed-cover-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 55vh;
    z-index: -1;
    background: #f5f5f5;
  }
  .full-bleed-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 4. 본문 영역 */
  .post-content-wrapper {
    margin-top: 45vh; /* 이미지 높이만큼 아래에서 시작하여 이미지를 덮으며 올라옴 */
    background: #fff;
    position: relative;
    z-index: 1;
    padding: 4rem 20px;
    min-height: 100vh;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.05); /* 덮는 느낌을 위한 그림자 */
  }
  .post-content-wrapper.no-cover {
    margin-top: 6rem;
    box-shadow: none;
  }

  /* 메타 정보 디자인 */
  .post-header {
    margin-bottom: 3rem;
    text-align: center;
  }
  .post-main-title {
    font-size: 2.5rem;
    margin: 0 0 1rem 0;
  }
  .post-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .date {
    color: #888;
    font-size: 1rem;
  }
  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .tag {
    background: #111;
    color: #fff;
    padding: 0.3rem 0.6rem;
    font-size: 0.85rem;
    text-decoration: none;
  }
</style>

<script>
  const postNavbar = document.getElementById('postNavbar');
  const coverContainer = document.getElementById('coverContainer');

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    // 1. 커버 이미지 페이드아웃 효과
    if (coverContainer) {
      const fadeRate = 350; // 숫자가 작을수록 빨리 투명해짐
      const opacity = Math.max(1 - scrollY / fadeRate, 0);
      coverContainer.style.opacity = opacity.toString();
    }

    // 2. 글로벌 헤더가 사라질 쯤 포스트 전용 메뉴바 노출
    if (scrollY > 100) {
      postNavbar?.classList.add('visible');
    } else {
      postNavbar?.classList.remove('visible');
    }
  });
</script>
