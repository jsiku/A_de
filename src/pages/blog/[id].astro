---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  // 1. 모든 글(메모 포함)을 날짜순으로 정렬합니다.
  const sortedAll = allEntries.sort((a, b) => {
    const isAPinned = a.data.pinned === true;
    const isBPinned = b.data.pinned === true;

    // ✨ u 설정: updated가 있으면 updated, 없으면 date의 타임스탬프 값 추출
    const aDate = a.data.updated ? a.data.updated.valueOf() : a.data.date.valueOf();
    const bDate = b.data.updated ? b.data.updated.valueOf() : b.data.date.valueOf();

    // 1순위: Pinned 상태 비교, 2순위: u(최신 날짜) 기준 정렬
    if (isAPinned === isBPinned) {
      return bDate - aDate;
    }
    return isAPinned ? -1 : 1;
  });

  // 2. 하단 이전/다음(older/newer) 링크 계산을 위해 일반 포스트만 따로 추려냅니다.
  const postsOnly = sortedAll.filter(p => p.data.type !== 'memo');

  // 3. 메모를 포함한 '모든 글'에 대해 고유 페이지 경로를 생성합니다.
  return sortedAll.map((post) => {
    let prevPost = null;
    let nextPost = null;

    // 현재 페이지가 일반 'post'일 때만 이전/다음 글 링크를 계산하여 연결합니다.
    if (post.data.type !== 'memo') {
      const index = postsOnly.findIndex(p => p.id === post.id);
      if (index !== -1) {
        prevPost = index + 1 < postsOnly.length ? postsOnly[index + 1] : null;
        nextPost = index - 1 >= 0 ? postsOnly[index - 1] : null;
      }
    }

    return {
      params: { id: post.id }, // 여기서 메모도 자신만의 고유 주소를 얻게 됩니다!
      props: {
        post,
        prevPost,
        nextPost,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

// ✨ 날짜 포맷 변환 함수 (DD. Mon. YYYY 형태)
function formatDate(dateStr: Date | string) {
  const d = new Date(dateStr);
  const day = String(d.getDate()).padStart(2, '0');
  const month = d.toLocaleString('en-US', { month: 'short' });
  const year = d.getFullYear();
  return `${day}. ${month}. ${year}`;
}

// ✨ 작성일 및 수정일 조합 (수정일이 있을 때만 Updated 문구 추가)
const createdStr = formatDate(post.data.date);
const updatedStr = post.data.updated ? ` (Updated ${formatDate(post.data.updated)})` : '';
const displayDate = createdStr + updatedStr;

// 형님께서 직접 수정하셨던 완벽한 날짜 포맷 로직 적용!
const postDate = new Date(post.data.date).toISOString().split('T')[0].replace(/-/g, '.');
---
<BaseLayout title={`${post.data.title || 'Post'} | Siku.name`}>

  <!-- 포스트 전용 고정 메뉴바 (겨자색 톤 적용) -->
  {post.data.type !== 'memo' && (
    <div class="post-navbar" id="postNavbar">
      <div class="post-navbar-inner">
        <a href={prevPost ? `/blog/${prevPost.id}` : '#'} class={!prevPost ? 'disabled' : ''}>&lt; older</a>
        <div class="center-menu">
          <a href="/" class="index-btn">▲ Index</a>
          <span class="reading-title">Reading: {post.data.title}</span>
        </div>
        <a href={nextPost ? `/blog/${nextPost.id}` : '#'} class={!nextPost ? 'disabled' : ''}>newer &gt;</a>
      </div>
    </div>
  )}

  <!-- 커버 이미지 영역: 화면을 좌우 꽉 채우고 고정 (패럴랙스) -->
  {post.data.cover && (
    <div id="fade-cover" class="fixed-cover-container">
      <!-- ✨ 여기서도 || 구문을 삭제하고 엄격하게 문자열인 .src만 넘겨줍니다 -->
      <img src={post.data.cover.src} alt="Cover" class="full-bleed-cover" />
    </div>
  )}


  <!-- 본문 영역: 이미지 밑에 있다가 위로 덮으며 올라옴 -->
  <article class={`post-content-wrapper ${!post.data.cover ? 'no-cover' : ''}`} data-pagefind-body>
     <div class="post-header prose">
        <h1 class="post-main-title">{post.data.title}</h1>
        <div class="post-meta">
          <span class="date">{postDate}</span>
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        </div>
     </div>

     <div class="prose">
        <Content />
     </div>
  </article>

</BaseLayout>

<style>
  /* 포스트 전용 고정 메뉴바 */
  .post-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #D4AF37;
    color: #111;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 2000;
  }
  .post-navbar.visible {
    transform: translateY(0);
  }
  .post-navbar-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.8rem 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
  }
  .post-navbar a { color: #111; text-decoration: none; transition: opacity 0.2s; }
  .post-navbar a:hover { opacity: 0.6; }
  .disabled { opacity: 0.3; pointer-events: none; }

  .center-menu {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .index-btn {
    transition: all 0.2s;
  }
  .index-btn:hover {
    background: rgba(255, 255, 255, 0.4);
  }
  .reading-title {
    font-weight: 500;
    opacity: 0.8;
  }

  /* 좌우 꽉 차는 고정 커버 이미지 (각진 모서리) */
  .fixed-cover-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 55vh;
    z-index: -1;
    background: #f5f5f5;
  }
  .full-bleed-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 본문 영역 */
  .post-content-wrapper {
    margin-top: 45vh; /* 이미지 높이만큼 아래에서 시작하여 이미지를 덮으며 올라옴 */
    background: #fff;
    position: relative;
    z-index: 1;
    padding: 4rem 20px;
    min-height: 100vh;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.05);
  }
  .post-content-wrapper.no-cover {
    margin-top: 2rem;
    box-shadow: none;
  }

  /* 메타 정보 디자인 */
  .post-header { margin-bottom: 3rem; text-align: center; }
  .post-main-title { font-size: 2.5rem; margin: 0 0 1rem 0; }
  .post-meta { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .date { color: #888; font-size: 1rem; font-family: monospace; }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
  .tag { background: #ccc; color: #666; padding: 0.3rem 0.6rem; font-size: 0.85rem; text-decoration: none; transition: background 0.2s; }
  .tag:hover { background: #D4AF37; color: #111; }

    .prose :global(img) {
    width: 900px !important;             /* prose의 기본 너비 제한을 강제로 뚫음 */
    height:auto !important;            /* 이미지의 원본 비율 유지 */
    max-width: 100vw !important;         /* 모바일에서는 화면 폭에 맞춤 */
    position: relative !important;
    left: 50% !important;                /* 부모(680px)의 중앙으로 왼쪽 끝을 밀어냄 */
    transform: translateX(-50%) !important; /* 이미지 폭의 절반만큼 다시 당겨서 완벽한 중앙 정렬 */
    display: block !important;
    margin-top: 3rem !important;         /* 이미지 위아래 여백 */
    margin-bottom: 3rem !important;
  }



</style>

<script>
  const postNavbar = document.getElementById('postNavbar');
  const coverContainer = document.getElementById('coverContainer');
  const globalHeader = document.querySelector('.site-header') as HTMLElement;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    // 1. 글로벌 헤더 숨기기 (단일 포스트에서만 작동)
    if (globalHeader) {
      if (scrollY > 50) {
        globalHeader.style.transform = 'translateY(-100%)';
        globalHeader.style.transition = 'transform 0.3s ease';
      } else {
        globalHeader.style.transform = 'translateY(0)';
      }
    }

    // 2. 커버 이미지 페이드아웃 효과
    if (coverContainer) {
      const fadeRate = 350;
      const opacity = Math.max(1 - scrollY / fadeRate, 0);
      coverContainer.style.opacity = opacity.toString();
    }

    // 3. 포스트 전용 겨자색 메뉴바 노출
    if (scrollY > 150) {
      postNavbar?.classList.add('visible');
    } else {
      postNavbar?.classList.remove('visible');
    }
  });
</script>
