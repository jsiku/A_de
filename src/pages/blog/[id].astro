---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');

  // 이전/다음 글 링크를 위해 memo를 제외한 포스트만 필터링 후 날짜순 정렬
  const posts = allEntries.filter(p => p.data.type !== 'memo').sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, index) => {
    return {
      params: { id: post.id },
      props: {
        post,
        prevPost: index + 1 < posts.length ? posts[index + 1] : null,
        nextPost: index - 1 >= 0 ? posts[index - 1] : null,
      }
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);


// 형님께서 직접 수정하셨던 완벽한 날짜 포맷 로직 적용!
const postDate = new Date(post.data.date).toISOString().split('T')[0].replace(/-/g, '.');
---
<BaseLayout title={`${post.data.title || 'Post'} | Siku.name`}>

  <!-- 포스트 전용 고정 메뉴바 (겨자색 톤 적용) -->
  <div class="post-navbar" id="postNavbar">
    <div class="post-navbar-inner">
      <a href={prevPost ? `/blog/${prevPost.id}` : '#'} class={!prevPost ? 'disabled' : ''}>&lt; older</a>
      <div class="center-menu">
        <a href="/" class="index-btn">▲ Index</a>
        <span class="reading-title">Reading: {post.data.title}</span>
      </div>
      <a href={nextPost ? `/blog/${nextPost.id}` : '#'} class={!nextPost ? 'disabled' : ''}>newer &gt;</a>
    </div>
  </div>

  <!-- 커버 이미지 영역: 화면을 좌우 꽉 채우고 고정 (패럴랙스) -->
  {post.data.cover && (
    <div id="fade-cover" class="fixed-cover-container">
      <!-- ✨ 여기서도 || 구문을 삭제하고 엄격하게 문자열인 .src만 넘겨줍니다 -->
      <img src={post.data.cover.src} alt="Cover" class="full-bleed-cover" />
    </div>
  )}


  <!-- 본문 영역: 이미지 밑에 있다가 위로 덮으며 올라옴 -->
  <article class={`post-content-wrapper ${!post.data.cover ? 'no-cover' : ''}`}>
     <div class="post-header prose">
        <h1 class="post-main-title">{post.data.title}</h1>
        <div class="post-meta">
          <span class="date">{postDate}</span>
          <div class="tags">
            {post.data.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </div>
        </div>
     </div>

     <div class="prose">
        <Content />
     </div>
  </article>

</BaseLayout>

<style>
  /* 포스트 전용 고정 메뉴바 */
  .post-navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: #D4AF37;
    color: #111;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 2000;
  }
  .post-navbar.visible {
    transform: translateY(0);
  }
  .post-navbar-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0.8rem 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
  }
  .post-navbar a { color: #111; text-decoration: none; transition: opacity 0.2s; }
  .post-navbar a:hover { opacity: 0.6; }
  .disabled { opacity: 0.3; pointer-events: none; }

  .center-menu {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .index-btn {
    transition: all 0.2s;
  }
  .index-btn:hover {
    background: rgba(255, 255, 255, 0.4);
  }
  .reading-title {
    font-weight: 500;
    opacity: 0.8;
  }

  /* 좌우 꽉 차는 고정 커버 이미지 (각진 모서리) */
  .fixed-cover-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 55vh;
    z-index: -1;
    background: #f5f5f5;
  }
  .full-bleed-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 본문 영역 */
  .post-content-wrapper {
    margin-top: 45vh; /* 이미지 높이만큼 아래에서 시작하여 이미지를 덮으며 올라옴 */
    background: #fff;
    position: relative;
    z-index: 1;
    padding: 4rem 20px;
    min-height: 100vh;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.05);
  }
  .post-content-wrapper.no-cover {
    margin-top: 2rem;
    box-shadow: none;
  }

  /* 메타 정보 디자인 */
  .post-header { margin-bottom: 3rem; text-align: center; }
  .post-main-title { font-size: 2.5rem; margin: 0 0 1rem 0; }
  .post-meta { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
  .date { color: #888; font-size: 1rem; font-family: monospace; }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
  .tag { background: #111; color: #fff; padding: 0.3rem 0.6rem; font-size: 0.85rem; text-decoration: none; transition: background 0.2s; }
  .tag:hover { background: #D4AF37; color: #111; }
</style>

<script>
  const postNavbar = document.getElementById('postNavbar');
  const coverContainer = document.getElementById('coverContainer');
  const globalHeader = document.querySelector('.site-header') as HTMLElement;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    // 1. 글로벌 헤더 숨기기 (단일 포스트에서만 작동)
    if (globalHeader) {
      if (scrollY > 50) {
        globalHeader.style.transform = 'translateY(-100%)';
        globalHeader.style.transition = 'transform 0.3s ease';
      } else {
        globalHeader.style.transform = 'translateY(0)';
      }
    }

    // 2. 커버 이미지 페이드아웃 효과
    if (coverContainer) {
      const fadeRate = 350;
      const opacity = Math.max(1 - scrollY / fadeRate, 0);
      coverContainer.style.opacity = opacity.toString();
    }

    // 3. 포스트 전용 겨자색 메뉴바 노출
    if (scrollY > 150) {
      postNavbar?.classList.add('visible');
    } else {
      postNavbar?.classList.remove('visible');
    }
  });
</script>
