---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

// 'hej' 타입의 글만 가져와 최신순 정렬
const allEntries = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const hejEntries = allEntries
  .filter(entry => entry.data.type === 'hej')
  .sort((a, b) => {
  const aDate = a.data.updated ? a.data.updated.valueOf() : a.data.date.valueOf();
  const bDate = b.data.updated ? b.data.updated.valueOf() : b.data.date.valueOf();
  return bDate - aDate;
});

// 가장 최신 글 1개만 선택
const latestHej = hejEntries.length > 0 ? hejEntries[0] : null;

let Content = null;
if (latestHej) {
  const rendered = await render(latestHej);
  Content = rendered.Content;
}
---
<BaseLayout title="Hej! | Siku.name">

  <!-- 중간 높이의 커버 이미지와 오버레이 텍스트 -->
  <div class="page-hero">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 1200 300" preserveAspectRatio="xMidYMid slice" class="hero-bg">
      <rect width="100%" height="100%" fill="#FFF8E1" />
      <circle cx="80%" cy="50%" r="150" fill="#FFE082" opacity="0.3"/>
      <path d="M0,300 L1200,250 L1200,300 Z" fill="#ffffff" opacity="0.5"/>
    </svg>
    <div class="hero-content">
      <h1>Hej!</h1>
      <p>소개와 구독 안내</p>
    </div>
  </div>

  <!-- 680px 본문 컨테이너 -->
  <div class="hej-container prose">
    {Content ? (
      <Content />
    ) : (
      <p>아직 작성된 Hej! 소개 글이 없습니다. (type: "hej"로 글을 작성해 보세요!)</p>
    )}
  </div>

</BaseLayout>

<style>
  /* 히어로 영역 (중간 높이) */
  .page-hero {
    position: relative;
    height: 30vh;
    min-height: 250px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-bottom: 4rem;
  }
  .hero-bg {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .hero-content h1 {
    font-size: 3.5rem;
    margin: 0 0 0.5rem 0;
    color: #111;
    letter-spacing: -1px;
  }
  .hero-content p {
    color: #555;
    font-size: 1.2rem;
    margin: 0;
  }

  .hej-container {
    padding-bottom: 0; /* 푸터와 밀착되도록 여백 제거 */
  }

  /* ✨ 푸터 블렌딩 마법
     본문 배경(흰색)이 하단 푸터(RSS 버튼 구역)까지 단절 없이 이어지도록
     첫 번째 푸터 영역(.footer-top)의 회색 배경을 흰색으로 덮어씌웁니다. */
  :global(.footer-top) {
    background-color: #fff !important;
    border-top: none !important;
    padding-top: 2rem !important; /* 본문과 자연스러운 간격 유지 */
  }
      .prose :global(img) {
    width: 900px !important;             /* prose의 기본 너비 제한을 강제로 뚫음 */
    max-width: 100vw !important;         /* 모바일에서는 화면 폭에 맞춤 */
    position: relative !important;
    left: 50% !important;                /* 부모(680px)의 중앙으로 왼쪽 끝을 밀어냄 */
    transform: translateX(-50%) !important; /* 이미지 폭의 절반만큼 다시 당겨서 완벽한 중앙 정렬 */
    display: block !important;
    margin-top: 3rem !important;         /* 이미지 위아래 여백 */
    margin-bottom: 3rem !important;
      }
</style>
