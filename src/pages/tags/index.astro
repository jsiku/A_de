---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

// 'tags' 타입의 글만 가져와 최신순 정렬
const allEntries = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const tagPosts = allEntries
  .filter(entry => entry.data.type === 'tags')
  .sort((a, b) => {
    const isAPinned = a.data.pinned === true;
    const isBPinned = b.data.pinned === true;

    // ✨ u 설정: updated가 있으면 updated, 없으면 date의 타임스탬프 값 추출
    const aDate = a.data.updated ? a.data.updated.valueOf() : a.data.date.valueOf();
    const bDate = b.data.updated ? b.data.updated.valueOf() : b.data.date.valueOf();

    // 1순위: Pinned 상태 비교, 2순위: u(최신 날짜) 기준 정렬
    if (isAPinned === isBPinned) {
      return bDate - aDate;
    }
    return isAPinned ? -1 : 1;
  }
);

// render()를 미리 모두 실행하기 위해 Promise.all 사용
const renderedPosts = await Promise.all(
  tagPosts.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---
<BaseLayout title="Tags | Siku.name">
  <div class="tags-intro-container prose">
    <h1 class="page-title">Tags</h1>
    <p class="page-desc">블로그를 관통하는 주요 주제와 태그들에 대한 이야기입니다.</p>

    <div class="tags-content-list">
      {renderedPosts.length > 0 ? (
        renderedPosts.map(({ post, Content }) => (
          <article class="tag-explainer">
            <h2 class="tag-title">#{post.data.title || post.id}</h2>
            <div class="prose">
              <Content />
            </div>
            <hr class="divider" />
          </article>
        ))
      ) : (
        <p>아직 작성된 태그 소개 글이 없습니다. (type: "tags"로 글을 작성해 보세요!)</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .tags-intro-container {
    margin-top: 4rem;
    padding-bottom: 6rem;
  }
  .page-title {
    font-size: 3rem;
    margin-bottom: 0.5rem;
  }
  .page-desc {
    color: #666;
    margin-bottom: 4rem;
  }
  .tag-explainer {
    margin-bottom: 4rem;
    width: 100%;
  }
  .tag-title {
    color: #111;
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }
  .divider {
    border: 0;
    border-top: 1px dashed #ccc;
    margin-top: 4rem;
  }
        .prose :global(img) {
    width: 900px !important;             /* prose의 기본 너비 제한을 강제로 뚫음 */
    max-width: 100vw !important;         /* 모바일에서는 화면 폭에 맞춤 */
    position: relative !important;
    left: 50% !important;                /* 부모(680px)의 중앙으로 왼쪽 끝을 밀어냄 */
    transform: translateX(-50%) !important; /* 이미지 폭의 절반만큼 다시 당겨서 완벽한 중앙 정렬 */
    display: block !important;
    margin-top: 3rem !important;         /* 이미지 위아래 여백 */
    margin-bottom: 3rem !important;
      }
</style>
