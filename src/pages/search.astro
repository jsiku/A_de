---
import BaseLayout from '../layouts/BaseLayout.astro';
import PagefindSearch from 'astro-pagefind/components/Search';
---
<BaseLayout title="Search | Siku.name">
  <div class="search-page-container">
    <a href="/" class="back-link">&lt; back to index</a>

    <!-- 서버 사이드 query={} 속성을 지우고 기본 설정만 남깁니다 -->
    <PagefindSearch
      id="search"
      className="custom-pagefind"
      uiOptions={{ showImages: false }}
    />
  </div>
</BaseLayout>

<style>
  /* 900px 중앙 정렬 컨테이너 */
  .search-page-container {
    max-width: 900px;
    margin: 4rem auto;
    padding: 0 20px;
    min-height: 60vh;
  }
  .back-link {
    color: #555;
    text-decoration: underline;
    font-weight: 500;
    font-size: 1rem;
    transition: color 0.2s;
    display: inline-block;
    margin-bottom: 2rem;
  }
  .back-link:hover { color: #111; }

  /* 공식 Pagefind UI를 에디토리얼 레이아웃으로 덮어씌우는 CSS */
  :global(.custom-pagefind .pagefind-ui__search-input) {
    width: 100%;
    padding: 1.2rem;
    border: 2px solid #111 !important;
    font-size: 1.2rem;
    background-color: #fff;
    border-radius: 0;
  }
  :global(.custom-pagefind .pagefind-ui__search-clear) { padding: 0 1rem; }
  :global(.custom-pagefind .pagefind-ui__results-area) { margin-top: 3rem; }
  :global(.custom-pagefind .pagefind-ui__result) {
    border-bottom: 1px solid #eaeaea !important;
    padding-bottom: 3rem !important;
    margin-bottom: 3rem !important;
    border-top: none !important;
    padding-top: 0 !important;
  }
  :global(.custom-pagefind .pagefind-ui__result-title) { margin: 0 0 0.8rem 0; font-size: 1.8rem; font-weight: bold; }
  :global(.custom-pagefind .pagefind-ui__result-title .pagefind-ui__result-link) { color: #111; text-decoration: none; }
  :global(.custom-pagefind .pagefind-ui__result-title .pagefind-ui__result-link:hover) { color: #D4AF37; }
  :global(.custom-pagefind .pagefind-ui__result-excerpt) { color: #555; line-height: 1.6; font-size: 1.05rem; margin: 0; }
  :global(.custom-pagefind .pagefind-ui__result-excerpt mark) {
    background: transparent !important;
    color: #111 !important;
    font-weight: 900 !important;
    border-bottom: 2px solid #111 !important;
  }
</style>

<!-- ✨ 핵심 추가: 클라이언트 사이드 자동 검색 스크립트 -->
<script>
  window.addEventListener('DOMContentLoaded', () => {
    // 1. 주소창에서 ?q=검색어 값을 가져옵니다.
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q');

    if (query) {
      // 2. Pagefind 검색창이 화면에 렌더링될 때까지 0.1초마다 확인합니다.
      const checkExist = setInterval(() => {
        const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement;
        if (input) {
          clearInterval(checkExist); // 창을 찾으면 반복 확인 종료

          // 3. 검색창에 단어를 넣고, 사람이 직접 타이핑한 것처럼 이벤트를 발생시킵니다!
          input.value = query;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }, 100);
    }
  });
</script>
